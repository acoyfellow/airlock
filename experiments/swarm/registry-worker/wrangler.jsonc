{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "airlock-swarm-registry",
  "main": "src/index.ts",
  "compatibility_date": "2025-06-01",
  "durable_objects": {
    "bindings": [
      { "name": "REGISTRY", "class_name": "PromotionRegistry" }
    ]
  },
  "migrations": [
    { "tag": "v1", "new_classes": ["PromotionRegistry"] }
  ],
  "observability": { "enabled": true }
}
